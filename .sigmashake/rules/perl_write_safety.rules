# perl_write_safety.rules
# Technology: perl | Capability: write

rule perl-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "UNSAFE_perl_PATTERN"
  MESSAGE "Blocked an unsafe pattern in perl. Use the recommended best practices for 2025/2026."
}

rule perl-force-updated-api {
  enabled true
  priority 80
  severity warning
  ASK write
  IF path GLOB "**/*" AND content CONTAINS "OLD_perl_API"
  MESSAGE "You are using an outdated API for perl. Please upgrade to the newer API."
}
